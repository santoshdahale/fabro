{
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "forwardPorts": [3000, "8080:80", "9090"],
  "remoteUser": "vscode",
  "remoteEnv": {
    "EDITOR": "code"
  },
  "containerEnv": {
    "DEBIAN_FRONTEND": "noninteractive"
  },
  "onCreateCommand": "setup.sh",
  "postCreateCommand": "echo hello"
}
